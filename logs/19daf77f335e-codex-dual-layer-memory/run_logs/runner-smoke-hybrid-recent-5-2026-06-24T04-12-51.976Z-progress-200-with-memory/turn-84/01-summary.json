  "selectedForNext": {
    "text": "沉默片刻，然后问她——‘那你呢？你在这个橱窗里，站在哪个位置？’"
  },
  "candidateActions": [],
  "choices": {
    "options": [
      {
        "text": "沉默片刻，然后问她——‘那你呢？你在这个橱窗里，站在哪个位置？’"
      },
      {
        "text": "顺着她的话说——‘是啊，比拍一座岛的全部秘密还难。你试过拍那个吗？’"
      },
      {
        "text": "端起那杯已经凉了的茶，喝了一口，然后说‘我想要的答案——可能需要有人告诉我它的轮廓在哪儿。’"
      },
      {
        "text": "目光落在黑猫身上，然后轻轻开口——‘你认识那个拿相机的局外人吗？’"
      }
    ]
  },
